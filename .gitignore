# Large / generated artifacts — not committed to git
# (NOTE: keep comments on their OWN lines — git treats an inline "# ..." as part
#  of the pattern, which is why these were not actually being ignored before.)

# raw + processed datasets (download separately)
data/
# fine-tuned transformer checkpoints (large)
models/
# generated results: keep the scores (JSON) and confusion-matrix figures (PNG),
# but not the big per-example prediction arrays
results/*.npz

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# OS / IDE
.DS_Store
.idea/
.ipynb_checkpoints/
